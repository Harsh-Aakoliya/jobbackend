How to run postgres container
docker run -d --name jobbackend -e POSTGRES_DB=jobbackend -e POSTGRES_USER=jobbackend -e POSTGRES_PASSWORD=jobbackend -p 5432:5432 postgres
docker rm jobbackend => to delete jobbackend container

How to run pgadmin container
docker run -d --name jobbackend_pgadmin -e PGADMIN_DEFAULT_EMAIL=admin@admin.com -e PGADMIN_DEFAULT_PASSWORD=pgadmin -p 5050:5050 dpage/pgadmin4

How to attach a network while creating containers
1) create network
docker network create jobbackend_network

now while running above command add: --network jobbackend to attach network to container


simple alternative docker compose file

services:
  postgres:
    container_name: jobbackend_postgres
    image: postgres
    environment:
      POSTGRES_USER: jobbackend
      POSTGRES_PASSWORD: jobbackend
    ports:
      - "5432:5432"
    networks:
      - jobbackend_network

  pgadmin:
    container_name: jobbackend_pgadmin
    image: dpage/pgadmin4
    environment:
      PGADMIN_DEFAULT_EMAIL: admin@adming.com
      PGADMIN_DEFAULT_PASSWORD: pgadmin
    ports:
      - "80:80"
    networks:
      - jobbackend_network

networks:
  jobbackend_network: